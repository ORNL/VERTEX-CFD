<ParameterList>

  <ParameterList name="Mesh">
    <Parameter name="Mesh Input Type" type="string" value="Inline"/>
    <ParameterList name="Inline">
      <Parameter name="Element Type" type="string" value="Hex8"/>
      <ParameterList name="Mesh">
        <Parameter name="X0" type="double" value="0.0"/>
        <Parameter name="Y0" type="double" value="0.0"/>
        <Parameter name="Z0" type="double" value="0.0"/>
        <Parameter name="Xf" type="double" value="1.0"/>
        <Parameter name="Yf" type="double" value="1.0"/>
        <Parameter name="Zf" type="double" value="1.0"/>
        <Parameter name="X Elements" type="int" value="25"/>
        <Parameter name="Y Elements" type="int" value="25"/>
        <Parameter name="Z Elements" type="int" value="25"/>
      </ParameterList> <!-- Mesh -->
    </ParameterList> <!-- Inline -->
  </ParameterList> <!-- Mesh -->

  <ParameterList name="Solution Output">
    <Parameter name="Exodus Output File" type="string" value="simple_box_3d_solution.exo"/>
    <Parameter name="Exodus Write Frequency" type="int" value="1"/>
  </ParameterList> <!-- Solution Output -->

  <ParameterList name="Block ID to Physics ID Mapping">
    <Parameter name="eblock-0_0_0" type="string" value="FluidPhysicsBlock"/>
  </ParameterList> <!-- Block ID to Physics ID Mapping -->

  <ParameterList name="Physics Blocks">
    <ParameterList name="FluidPhysicsBlock">
      <ParameterList>
        <Parameter name="Type" type="string" value="IncompressibleNavierStokes"/>
        <Parameter name="Basis Order" type="int" value="1"/>
        <Parameter name="Integration Order" type="int" value="2"/>
        <Parameter name="Model ID" type="string" value="fluids"/>
        <Parameter name="Build Viscous Flux" type="bool" value="true"/>
        <Parameter name="Build Temperature Equation" type="bool" value="true"/>
        <Parameter name="Turbulence Model" type="string" value="Spalart-Allmaras"/>
        <Parameter name="Build Constant Source" type="bool" value="true"/>
        <Parameter name="Build Buoyancy Source" type="bool" value="true"/>
        <Parameter name="Build Inductionless MHD Equation" type="bool" value="true"/>
      </ParameterList> <!-- -->
    </ParameterList> <!-- FluidPhysicsBlock -->
  </ParameterList> <!-- Physics Blocks -->

  <ParameterList name="User Data">
    <Parameter name="Build Transient Support" type="bool" value="true"/>
    <Parameter name="Output Graph" type="bool" value="false"/>
    <Parameter name="Workset Size" type="int" value="256"/>
    <Parameter name="CFL" type="double" value="1.0"/>
    <Parameter name="Build Viscous Flux" type="bool" value="true"/>
    <Parameter name="Build Temperature Equation" type="bool" value="true"/>
    <Parameter name="Build Inductionless MHD Equation" type="bool" value="true"/>
    <Parameter name="Turbulence Model" type="string" value="Spalart-Allmaras"/>
    <Parameter name="Wall Names" type="string" value="top,bottom"/>
    <Parameter name="Build Buoyancy Source" type="bool" value="true"/>
    <Parameter name="Gravity" type="Array(double)" value="{0.0, 0.0, -10.0}"/>
    <Parameter name="External Magnetic Field Value" type="Array(double)" value="{0.0, 1.0, 0.0}"/>
  </ParameterList> <!-- User Data -->

  <ParameterList name="Boundary Conditions">
    <ParameterList>
      <Parameter name="Sideset ID" type="string" value="top"/>
      <Parameter name="Element Block ID" type="string" value="eblock-0_0_0"/>
      <Parameter name="Strategy" type="string" value="IncompressibleBoundaryFlux"/>
      <ParameterList name="Data">
        <ParameterList name="Navier-Stokes">
          <Parameter name="Type" type="string" value="Dirichlet"/>
          <Parameter name="velocity_0" type="double" value="1.0"/>
          <Parameter name="velocity_1" type="double" value="2.0"/>
          <Parameter name="velocity_2" type="double" value="3.0"/>
          <Parameter name="temperature" type="double" value="4.0"/>
        </ParameterList> <!-- Navier-Stokes -->
        <ParameterList name="Turbulence Model">
          <Parameter name="Type" type="string" value="Fixed"/>
          <Parameter name="spalart_allmaras_variable Value" type="double" value="0.0"/>
        </ParameterList> <!-- Turbulence Model -->
        <ParameterList name="Electric Potential">
          <Parameter name="Type" type="string" value="ElectricPotentialInsulatingWall"/>
        </ParameterList> <!-- Electric Potential -->
      </ParameterList> <!-- Data -->
    </ParameterList> <!-- -->
    <ParameterList>
      <Parameter name="Sideset ID" type="string" value="bottom"/>
      <Parameter name="Element Block ID" type="string" value="eblock-0_0_0"/>
      <Parameter name="Strategy" type="string" value="IncompressibleBoundaryFlux"/>
      <ParameterList name="Data">
        <ParameterList name="Navier-Stokes">
          <Parameter name="Type" type="string" value="No-Slip"/>
          <Parameter name="Wall Temperature" type="double" value="3.0"/>
        </ParameterList> <!-- Navier-Stokes -->
        <ParameterList name="Turbulence Model">
          <Parameter name="Type" type="string" value="Fixed"/>
          <Parameter name="spalart_allmaras_variable Value" type="double" value="0.0"/>
        </ParameterList> <!-- Turbulence Model -->
        <ParameterList name="Electric Potential">
          <Parameter name="Type" type="string" value="ElectricPotentialInsulatingWall"/>
        </ParameterList> <!-- Electric Potential -->
      </ParameterList> <!-- Data -->
    </ParameterList> <!-- -->
    <ParameterList>
      <Parameter name="Sideset ID" type="string" value="right"/>
      <Parameter name="Element Block ID" type="string" value="eblock-0_0_0"/>
      <Parameter name="Strategy" type="string" value="IncompressibleBoundaryFlux"/>
      <ParameterList name="Data">
        <ParameterList name="Navier-Stokes">
          <Parameter name="Type" type="string" value="Symmetry"/>
        </ParameterList> <!-- Navier-Stokes -->
        <ParameterList name="Turbulence Model">
          <Parameter name="Type" type="string" value="InletOutlet"/>
          <Parameter name="spalart_allmaras_variable Inlet Value" type="double" value="2.0"/>
        </ParameterList> <!-- Turbulence Model -->
        <ParameterList name="Electric Potential">
          <Parameter name="Type" type="string" value="ElectricPotentialInsulatingWall"/>
        </ParameterList> <!-- Electric Potential -->
      </ParameterList> <!-- Data -->
    </ParameterList> <!-- -->
    <ParameterList>
      <Parameter name="Sideset ID" type="string" value="left"/>
      <Parameter name="Element Block ID" type="string" value="eblock-0_0_0"/>
      <Parameter name="Strategy" type="string" value="IncompressibleBoundaryFlux"/>
      <ParameterList name="Data">
        <ParameterList name="Navier-Stokes">
          <Parameter name="Type" type="string" value="Pressure Outflow"/>
          <Parameter name="Back Pressure" type="double" value="0.5"/>
        </ParameterList> <!-- Navier-Stokes -->
        <ParameterList name="Turbulence Model">
          <Parameter name="Type" type="string" value="Fixed"/>
          <Parameter name="spalart_allmaras_variable Value" type="double" value="0.0"/>
        </ParameterList> <!-- Turbulence Model -->
        <ParameterList name="Electric Potential">
          <Parameter name="Type" type="string" value="ElectricPotentialInsulatingWall"/>
        </ParameterList> <!-- Electric Potential -->
      </ParameterList> <!-- Data -->
    </ParameterList> <!-- -->
    <ParameterList>
      <Parameter name="Sideset ID" type="string" value="front"/>
      <Parameter name="Element Block ID" type="string" value="eblock-0_0_0"/>
      <Parameter name="Strategy" type="string" value="IncompressibleBoundaryFlux"/>
      <ParameterList name="Data">
        <ParameterList name="Navier-Stokes">
          <Parameter name="Type" type="string" value="Rotating Wall"/>
          <Parameter name="Angular Velocity" type="double" value="2.0"/>
          <Parameter name="Wall Temperature" type="double" value="2.0"/>
        </ParameterList> <!-- Navier-Stokes -->
        <ParameterList name="Turbulence Model">
          <Parameter name="Type" type="string" value="Symmetry"/>
        </ParameterList> <!-- Turbulence Model -->
        <ParameterList name="Electric Potential">
          <Parameter name="Type" type="string" value="ElectricCurrentDensityInsulating"/>
        </ParameterList> <!-- Electric Potential -->
      </ParameterList> <!-- Data -->
    </ParameterList> <!-- -->
    <ParameterList>
      <Parameter name="Sideset ID" type="string" value="back"/>
      <Parameter name="Element Block ID" type="string" value="eblock-0_0_0"/>
      <Parameter name="Strategy" type="string" value="IncompressibleBoundaryFlux"/>
      <ParameterList name="Data">
        <ParameterList name="Navier-Stokes">
          <Parameter name="Type" type="string" value="Laminar Flow"/>
          <Parameter name="Characteristic Radius" type="double" value="0.1"/>
          <Parameter name="Average velocity" type="double" value="0.1"/>
          <Parameter name="Temperature" type="double" value="0.1"/>
        </ParameterList> <!-- Navier-Stokes -->
        <ParameterList name="Turbulence Model">
          <Parameter name="Type" type="string" value="Extrapolate"/>
        </ParameterList> <!-- Turbulence Model -->
        <ParameterList name="Electric Potential">
          <Parameter name="Type" type="string" value="Fixed"/>
          <Parameter name="Final Value" type="double" value="0.0"/>
        </ParameterList> <!-- Electric Potential -->
      </ParameterList> <!-- Data -->
    </ParameterList> <!-- -->
  </ParameterList> <!-- Boundary Conditions -->

  <ParameterList name="Initial Conditions">
    <ParameterList name="eblock-0_0_0">
      <ParameterList name="Constant Lagrange Pressure">
        <Parameter name="Type" type="string" value="Constant"/>
        <Parameter name="Equation Set Name" type="string" value="lagrange_pressure"/>
        <Parameter name="Value" type="double" value="0.5"/>
      </ParameterList> <!-- Constant Lagrange Pressure -->
      <ParameterList name="Constant Velocity 0">
        <Parameter name="Type" type="string" value="Constant"/>
        <Parameter name="Equation Set Name" type="string" value="velocity_0"/>
        <Parameter name="Value" type="double" value="1.0"/>
      </ParameterList> <!-- Constant Velocity 0 -->
      <ParameterList name="Constant Velocity 1">
        <Parameter name="Type" type="string" value="Constant"/>
        <Parameter name="Equation Set Name" type="string" value="velocity_1"/>
        <Parameter name="Value" type="double" value="2.0"/>
      </ParameterList> <!-- Constant Velocity 1 -->
      <ParameterList name="Constant Velocity 2">
        <Parameter name="Type" type="string" value="Constant"/>
        <Parameter name="Equation Set Name" type="string" value="velocity_2"/>
        <Parameter name="Value" type="double" value="3.0"/>
      </ParameterList> <!-- Constant Velocity 2 -->
      <ParameterList name="Constant Temperature">
        <Parameter name="Type" type="string" value="Constant"/>
        <Parameter name="Equation Set Name" type="string" value="temperature"/>
        <Parameter name="Value" type="double" value="4.0"/>
      </ParameterList> <!-- Constant Temperature -->
      <ParameterList name="Spalart-Allmaras">
        <Parameter name="Type" type="string" value="Constant"/>
        <Parameter name="Equation Set Name" type="string" value="spalart_allmaras_variable"/>
        <Parameter name="Value" type="double" value="0.00031"/>
      </ParameterList> <!-- Spalart-Allmaras -->
      <ParameterList name="Constant Electric Potential">
        <Parameter name="Type" type="string" value="Constant"/>
        <Parameter name="Equation Set Name" type="string" value="electric_potential"/>
        <Parameter name="Value" type="double" value="2.0"/>
      </ParameterList> <!-- Constant Electric Potential -->
    </ParameterList> <!-- eblock-0_0_0 -->
  </ParameterList> <!-- Initial Conditions -->

  <ParameterList name="Closure Models">
    <ParameterList name="fluids">
      <ParameterList name="Fluid Properties">
        <Parameter name="Kinematic viscosity" type="double" value="0.1"/>
        <Parameter name="Artificial compressibility" type="double" value="100.0"/>
        <Parameter name="Thermal conductivity" type="double" value="0.1"/>
        <Parameter name="Specific heat capacity" type="double" value="1.5"/>
        <Parameter name="Expansion coefficient" type="double" value="0.014285715"/>
        <Parameter name="Reference temperature" type="double" value="200.0"/>
        <Parameter name="Electrical conductivity" type="double" value="1.0"/>
      </ParameterList> <!-- Fluid Properties -->
      <ParameterList name="DQDT">
        <Parameter name="Type" type="string" value="IncompressibleTimeDerivative"/>
      </ParameterList> <!-- DQDT -->
      <ParameterList name="CONVECTIVE_FLUX">
        <Parameter name="Type" type="string" value="IncompressibleConvectiveFlux"/>
      </ParameterList> <!-- CONVECTIVE_FLUX -->
      <ParameterList name="VISCOUS_FLUX">
        <Parameter name="Type" type="string" value="IncompressibleViscousFlux"/>
      </ParameterList> <!-- VISCOUS_FLUX -->
      <ParameterList name="CONSTANT_SOURCE">
        <Parameter name="Type" type="string" value="IncompressibleConstantSource"/>
        <Parameter name="Momentum Source" type="Array(double)" value="{0.02785, 0.0, 0.0}"/>
        <Parameter name="Energy Source" type="double" value="0.0"/>
      </ParameterList> <!-- CONSTANT_SOURCE -->
      <ParameterList name="BUOYANCY_SOURCE">
        <Parameter name="Type" type="string" value="IncompressibleBuoyancySource"/>
      </ParameterList> <!-- BUOYANCY_SOURCE -->
      <ParameterList name="VISCOUS_HEATING">
        <Parameter name="Type" type="string" value="IncompressibleViscousHeat"/>
      </ParameterList> <!-- VISCOUS_HEATING -->
      <ParameterList name="element_length">
        <Parameter name="Type" type="string" value="ElementLength"/>
      </ParameterList> <!-- element_length -->
      <ParameterList name="local_time_step_size">
        <Parameter name="Type" type="string" value="IncompressibleLocalTimeStepSize"/>
      </ParameterList> <!-- local_time_step_size -->
      <ParameterList name="ERROR_NORM">
        <Parameter name="Type" type="string" value="IncompressibleErrorNorm"/>
      </ParameterList> <!-- ERROR_NORM -->
      <ParameterList name="EXACT">
        <Parameter name="Type" type="string" value="IncompressiblePlanarPoiseuilleExact"/>
        <Parameter name="Density" type="double" value="1.0"/>
        <Parameter name="Kinematic viscosity" type="double" value="0.1"/>
        <Parameter name="Thermal conductivity" type="double" value="0.1"/>
        <Parameter name="Specific heat capacity" type="double" value="1.5"/>
        <Parameter name="H min" type="double" value="-0.05"/>
        <Parameter name="H max" type="double" value="0.05"/>
        <Parameter name="Upper wall temperature" type="double" value="300.0"/>
        <Parameter name="Lower wall temperature" type="double" value="305.0"/>
        <Parameter name="Momentum source" type="double" value="24000"/>
      </ParameterList> <!-- EXACT -->
      <ParameterList name="WALL_DISTANCE">
        <Parameter name="Type" type="string" value="WallDistance"/>
      </ParameterList> <!-- WALL_DISTANCE -->
      <ParameterList name="EP_DIFFUSION">
        <Parameter name="Type" type="string" value="ElectricPotentialDiffusionFlux"/>
      </ParameterList> <!-- EP_DIFFUSION -->
      <ParameterList name="EP_CROSS_PRODUCT">
        <Parameter name="Type" type="string" value="ElectricPotentialCrossProductFlux"/>
      </ParameterList> <!-- EP_CROSS_PRODUCT -->
      <ParameterList name="ext_magn_field">
        <Parameter name="Type" type="string" value="ExternalMagneticField"/>
      </ParameterList> <!-- ext_magn_field -->
      <ParameterList name="elec_current_density">
        <Parameter name="Type" type="string" value="ElectricCurrentDensity"/>
      </ParameterList> <!-- elec_current_density -->
      <ParameterList name="lorentz_force">
        <Parameter name="Type" type="string" value="LorentzForce"/>
      </ParameterList> <!-- lorentz_force -->
    </ParameterList> <!-- fluids -->
  </ParameterList> <!-- Closure Models -->

  <ParameterList name="Linear Solver">
    <Parameter name="Linear Solver Type" type="string" value="Belos"/>
    <Parameter name="Preconditioner Type" type="string" value="Ifpack2"/>
    <ParameterList name="Linear Solver Types">
      <ParameterList name="Amesos2">
        <ParameterList name="VerboseObject">
          <Parameter name="Verbosity Level" type="string" value="none"/>
        </ParameterList> <!-- VerboseObject -->
      </ParameterList> <!-- Amesos2 -->
      <ParameterList name="Belos">
        <ParameterList name="VerboseObject">
          <Parameter name="Verbosity Level" type="string" value="none"/>
        </ParameterList> <!-- VerboseObject -->
      </ParameterList> <!-- Belos -->
    </ParameterList> <!-- Linear Solver Types -->
  </ParameterList> <!-- Linear Solver -->

  <ParameterList name="Tempus">
    <Parameter name="Integrator Name" type="string" value="Default Integrator"/>
    <ParameterList name="Default Integrator">
      <Parameter name="Integrator Type" type="string" value="Integrator Basic"/>
      <Parameter name="Stepper Name" type="string" value="Default Stepper"/>
      <ParameterList name="Solution History">
        <Parameter name="Storage Type" type="string" value="Undo"/>
        <Parameter name="Storage Limit" type="int" value="2"/>
      </ParameterList> <!-- Solution History -->
      <ParameterList name="Time Step Control">
        <Parameter name="Initial Time" type="double" value="0.0"/>
        <Parameter name="Final Time" type="double" value="0.01"/>
        <Parameter name="Final Time Index" type="int" value="1"/>
        <Parameter name="Minimum Time Step" type="double" value="0.0001"/>
        <Parameter name="Initial Time Step" type="double" value="0.0001"/>
        <Parameter name="Maximum Time Step" type="double" value="0.1"/>
        <Parameter name="Minimum Order" type="int" value="1"/>
        <Parameter name="Initial Order" type="int" value="1"/>
        <Parameter name="Maximum Order" type="int" value="2"/>
        <Parameter name="Maximum Absolute Error" type="double" value="1.0e-8"/>
        <Parameter name="Maximum Relative Error" type="double" value="1.0e-8"/>
        <Parameter name="Integrator Step Type" type="string" value="Constant"/>
        <Parameter name="Maximum Number of Stepper Failures" type="int" value="10"/>
        <Parameter name="Maximum Number of Consecutive Stepper Failures" type="int" value="5"/>
      </ParameterList> <!-- Time Step Control -->
    </ParameterList> <!-- Default Integrator -->
    <ParameterList name="Default Stepper">
      <Parameter name="Stepper Type" type="string" value="Backward Euler"/>
      <Parameter name="Solver Name" type="string" value="Default Solver"/>
      <Parameter name="Zero Initial Guess" type="bool" value="false"/>
      <ParameterList name="Default Solver">
        <ParameterList name="NOX">
          <ParameterList name="Direction">
            <Parameter name="Method" type="string" value="Newton"/>
            <ParameterList name="Newton">
              <Parameter name="Forcing Term Method" type="string" value="Constant"/>
              <Parameter name="Rescue Bad Newton Solve" type="bool" value="1"/>
              <ParameterList name="Stratimikos Linear Solver">
                <ParameterList name="NOX Stratimikos Options">
                </ParameterList>
              </ParameterList> <!-- Stratimikos Linear Solver -->
            </ParameterList> <!-- Newton -->
          </ParameterList> <!-- Direction -->
          <ParameterList name="Line Search">
            <Parameter name="Method" type="string" value="Full Step"/>
            <ParameterList name="Full Step">
              <Parameter name="Full Step" type="double" value="1"/>
            </ParameterList> <!-- Full Step -->
          </ParameterList> <!-- Line Search -->
          <Parameter name="Nonlinear Solver" type="string" value="Line Search Based"/>
          <ParameterList name="Printing">
            <Parameter name="Output Precision" type="int" value="3"/>
            <Parameter name="Output Processor" type="int" value="0"/>
            <ParameterList name="Output Information">
              <Parameter name="Error" type="bool" value="1"/>
              <Parameter name="Warning" type="bool" value="1"/>
              <Parameter name="Outer Iteration" type="bool" value="0"/>
              <Parameter name="Parameters" type="bool" value="0"/>
              <Parameter name="Details" type="bool" value="0"/>
              <Parameter name="Linear Solver Details" type="bool" value="0"/>
              <Parameter name="Stepper Iteration" type="bool" value="0"/>
              <Parameter name="Stepper Details" type="bool" value="0"/>
              <Parameter name="Stepper Parameters" type="bool" value="0"/>
            </ParameterList> <!-- Output Information -->
          </ParameterList> <!-- Printing -->
          <ParameterList name="Solver Options">
            <Parameter name="Status Test Check Type" type="string" value="Minimal"/>
          </ParameterList> <!-- Solver Options -->
          <ParameterList name="Status Tests">
            <Parameter name="Test Type" type="string" value="Combo"/>
            <Parameter name="Combo Type" type="string" value="OR"/>
            <Parameter name="Number of Tests" type="int" value="2"/>
            <ParameterList name="Test 0">
              <Parameter name="Test Type" type="string" value="NormF"/>
              <Parameter name="Tolerance" type="double" value="1.0e-8"/>
            </ParameterList> <!-- Test 0 -->
            <ParameterList name="Test 1">
              <Parameter name="Test Type" type="string" value="MaxIters"/>
              <Parameter name="Maximum Iterations" type="int" value="10"/>
            </ParameterList> <!-- Test 1 -->
          </ParameterList> <!-- Status Tests -->
        </ParameterList> <!-- NOX -->
      </ParameterList> <!-- Default Solver -->
    </ParameterList> <!-- Default Stepper -->
  </ParameterList> <!-- Tempus -->

</ParameterList>