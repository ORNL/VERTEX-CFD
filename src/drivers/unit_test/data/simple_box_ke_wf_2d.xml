<ParameterList>

  <ParameterList name="Mesh">
    <Parameter name="Mesh Input Type" type="string" value="Inline"/>
    <ParameterList name="Inline">
      <Parameter name="Element Type" type="string" value="Quad4"/>
      <ParameterList name="Mesh">
        <Parameter name="X0" type="double" value="0.0"/>
        <Parameter name="Y0" type="double" value="0.0"/>
        <Parameter name="Xf" type="double" value="1.0"/>
        <Parameter name="Yf" type="double" value="1.0"/>
        <Parameter name="X Elements" type="int" value="25"/>
        <Parameter name="Y Elements" type="int" value="25"/>
      </ParameterList> <!-- Mesh -->
    </ParameterList> <!-- Inline -->
  </ParameterList> <!-- Mesh -->

  <ParameterList name="Solution Output">
    <Parameter name="Exodus Output File" type="string" value="incompressible_2d_k_epsilon_turbulent_backward_step_solution.exo"/>
    <Parameter name="Exodus Write Frequency" type="int" value="100"/>
    <ParameterList name="Cell Average Quantities">
      <Parameter name="eblock-0_0" type="string" value="turbulent_eddy_viscosity"/>
    </ParameterList> <!-- Cell Average Quantities -->
    <ParameterList name="Cell Average Vectors">
      <Parameter name="eblock-0_0" type="string" value="GRAD_velocity_0, GRAD_velocity_1"/>
    </ParameterList> <!-- Cell Average Vectors -->
  </ParameterList> <!-- Solution Output -->

  <ParameterList name="Write Restart">
    <Parameter name="Write Restart" type="bool" value="false"/>
    <Parameter name="Restart File Prefix" type="string" value="incompressible_2d_k_epsilon_turbulent_backward_step"/>
    <Parameter name="Restart Write Frequency" type="int" value="1000"/>
  </ParameterList> <!-- Write Restart -->

  <ParameterList name="Read Restart">
    <Parameter name="Read Restart" type="bool" value="false"/>
    <Parameter name="Restart Data File Name" type="string" value="incompressible_2d_k_epsilon_turbulent_backward_step_100000.restart.data"/>
    <Parameter name="Restart DOF Map File Name" type="string" value="incompressible_2d_k_epsilon_turbulent_backward_step.restart.dofmap"/>
  </ParameterList> <!-- Read Restart -->

  <ParameterList name="Block ID to Physics ID Mapping">
    <Parameter name="eblock-0_0" type="string" value="FluidPhysicsBlock"/>
  </ParameterList> <!-- Block ID to Physics ID Mapping -->

  <ParameterList name="Physics Blocks">
    <ParameterList name="FluidPhysicsBlock">
      <ParameterList>
        <Parameter name="Type" type="string" value="IncompressibleNavierStokes"/>
        <Parameter name="Basis Order" type="int" value="1"/>
        <Parameter name="Integration Order" type="int" value="2"/>
        <Parameter name="Model ID" type="string" value="fluids"/>
        <Parameter name="Turbulence Model Name" type="string" value="Standard K-Epsilon"/>
      </ParameterList> <!-- -->
    </ParameterList> <!-- FluidPhysicsBlock -->
  </ParameterList> <!-- Physics Blocks -->

  <ParameterList name="User Data">
    <Parameter name="Output Graph" type="bool" value="false"/>
    <Parameter name="Workset Size" type="int" value="256"/>
    <Parameter name="CFL" type="double" value="1.0"/>
    <Parameter name="CFL_init" type="double" value="0.1"/>
    <Parameter name="CFL_transition" type="double" value="100"/>
  </ParameterList> <!-- User Data -->

  <ParameterList name="Boundary Conditions">
    <ParameterList>
      <Parameter name="Sideset ID" type="string" value="left"/>
      <Parameter name="Element Block ID" type="string" value="eblock-0_0"/>
      <Parameter name="Strategy" type="string" value="IncompressibleBoundaryFlux"/>
      <ParameterList name="Data">
        <ParameterList name="Navier-Stokes">
          <Parameter name="Type" type="string" value="Dirichlet"/>
          <Parameter name="velocity_0" type="double" value="1.0"/>
          <Parameter name="velocity_1" type="double" value="0.0"/>
        </ParameterList> <!-- Navier-Stokes -->
        <ParameterList name="Turbulence Model">
          <Parameter name="Type" type="string" value="Fixed"/>
          <Parameter name="turb_kinetic_energy Value" type="double" value="0.06"/>
          <Parameter name="turb_dissipation_rate Value" type="double" value="0.0495"/>
        </ParameterList> <!-- Turbulence Model -->
      </ParameterList> <!-- Data -->
    </ParameterList> <!-- -->
    <ParameterList>
      <Parameter name="Sideset ID" type="string" value="right"/>
      <Parameter name="Element Block ID" type="string" value="eblock-0_0"/>
      <Parameter name="Strategy" type="string" value="IncompressibleBoundaryFlux"/>
      <ParameterList name="Data">
        <ParameterList name="Navier-Stokes">
          <Parameter name="Type" type="string" value="Pressure Outflow"/>
          <Parameter name="Back Pressure" type="double" value="0.0"/>
        </ParameterList> <!-- Navier-Stokes -->
        <ParameterList name="Turbulence Model">
          <Parameter name="Type" type="string" value="Extrapolate"/>
        </ParameterList> <!-- Turbulence Model -->
      </ParameterList> <!-- Data -->
    </ParameterList> <!-- -->
    <ParameterList>
      <Parameter name="Sideset ID" type="string" value="bottom"/>
      <Parameter name="Element Block ID" type="string" value="eblock-0_0"/>
      <Parameter name="Strategy" type="string" value="IncompressibleBoundaryFlux"/>
      <ParameterList name="Data">`
	<ParameterList name="Navier-Stokes">
          <Parameter name="Type" type="string" value="Velocity Wall Function"/>
        </ParameterList> <!-- Navier-Stokes -->
        <ParameterList name="Turbulence Model">
          <Parameter name="Type" type="string" value="K-Epsilon Wall Function"/>
          <Parameter name="Epsilon Condition Type" type="string" value="Neumann"/>
        </ParameterList> <!-- Turbulence Model -->
      </ParameterList> <!-- Data -->
    </ParameterList> <!-- -->
    <ParameterList>
      <Parameter name="Sideset ID" type="string" value="top"/>
      <Parameter name="Element Block ID" type="string" value="eblock-0_0"/>
      <Parameter name="Strategy" type="string" value="IncompressibleBoundaryFlux"/>
      <ParameterList name="Data">`
        <ParameterList name="Navier-Stokes">
          <Parameter name="Type" type="string" value="Velocity Wall Function"/>
        </ParameterList> <!-- Navier-Stokes -->
        <ParameterList name="Turbulence Model">
          <Parameter name="Type" type="string" value="K-Epsilon Wall Function"/>
          <Parameter name="Epsilon Condition Type" type="string" value="Neumann"/>
        </ParameterList> <!-- Turbulence Model -->
      </ParameterList> <!-- Data -->
    </ParameterList> <!-- -->
  </ParameterList> <!-- Boundary Conditions -->

  <ParameterList name="Initial Conditions">
    <ParameterList name="eblock-0_0">
      <ParameterList name="Laminar Flow">
        <Parameter name="Type" type="string" value="IncompressibleLaminarFlow"/>
        <Parameter name="Minimum height" type="double" value="1.0"/>
        <Parameter name="Maximum height" type="double" value="9.0"/>
        <Parameter name="Average velocity" type="double" value="1.0"/>
      </ParameterList> <!-- Laminar Flow -->
      <ParameterList name="Constant Turbulent Kinetic Energy">
        <Parameter name="Type" type="string" value="Constant"/>
        <Parameter name="Equation Set Name" type="string" value="turb_kinetic_energy"/>
        <Parameter name="Value" type="double" value="0.06"/>
      </ParameterList> <!-- Constant Turbulent Kinetic Energy -->
      <ParameterList name="Constant Turbulent Dissipation Rate">
        <Parameter name="Type" type="string" value="Constant"/>
        <Parameter name="Equation Set Name" type="string" value="turb_dissipation_rate"/>
        <Parameter name="Value" type="double" value="0.0495"/>
      </ParameterList> <!-- Constant Turbulent Dissipation Rate -->
    </ParameterList> <!-- eblock-0_0 -->
  </ParameterList> <!-- Initial Conditions -->

  <ParameterList name="Closure Models">
    <ParameterList name="fluids">
      <ParameterList name="Fluid Properties">
        <Parameter name="Kinematic viscosity" type="double" value="2.78e-5"/>
        <Parameter name="Artificial compressibility" type="double" value="100.0"/>
        <Parameter name="Continuity Model" type="string" value="AC"/>
      </ParameterList> <!-- Fluid Properties -->
      <ParameterList name="Turbulence Parameters">
        <Parameter name="Turbulence Model Name" type="string" value="Standard K-Epsilon"/>
      </ParameterList> <!-- Turbulence Parameters -->
      <ParameterList name="DQDT">
        <Parameter name="Type" type="string" value="IncompressibleTimeDerivative"/>
      </ParameterList> <!-- DQDT -->
      <ParameterList name="CONVECTIVE_FLUX">
        <Parameter name="Type" type="string" value="IncompressibleConvectiveFlux"/>
      </ParameterList> <!-- CONVECTIVE_FLUX -->
      <ParameterList name="VISCOUS_FLUX">
        <Parameter name="Type" type="string" value="IncompressibleViscousFlux"/>
      </ParameterList> <!-- VISCOUS_FLUX -->
      <ParameterList name="element_length">
        <Parameter name="Type" type="string" value="ElementLength"/>
      </ParameterList> <!-- element_length -->
      <ParameterList name="local_time_step_size">
        <Parameter name="Type" type="string" value="IncompressibleLocalTimeStepSize"/>
      </ParameterList> <!-- local_time_step_size -->
    </ParameterList> <!-- fluids -->
  </ParameterList> <!-- Closure Models -->

  <ParameterList name="Linear Solver">
    <Parameter name="Linear Solver Type" type="string" value="Belos"/>
    <Parameter name="Preconditioner Type" type="string" value="Ifpack2"/>
    <ParameterList name="Linear Solver Types">
      <ParameterList name="Amesos2">
        <ParameterList name="VerboseObject">
          <Parameter name="Verbosity Level" type="string" value="none"/>
        </ParameterList> <!-- VerboseObject -->
      </ParameterList> <!-- Amesos2 -->
      <ParameterList name="Belos">
        <ParameterList name="VerboseObject">
          <Parameter name="Verbosity Level" type="string" value="none"/>
        </ParameterList> <!-- VerboseObject -->
      </ParameterList> <!-- Belos -->
    </ParameterList> <!-- Linear Solver Types -->
    <ParameterList name="Preconditioner Types">
      <ParameterList name="Ifpack2">
        <Parameter name="Prec Type" type="string" value="Amesos2"/>
        <Parameter name="Overlap" type="int" value="2"/>
        <ParameterList name="VerboseObject">
          <Parameter name="Verbosity Level" type="string" value="none"/>
        </ParameterList> <!-- VerboseObject -->
      </ParameterList> <!-- Ifpack2 -->
      <ParameterList name="Ifpack">
        <Parameter name="Prec Type" type="string" value="Amesos"/>
        <Parameter name="Overlap" type="int" value="1"/>
        <ParameterList name="Ifpack Settings">
          <Parameter name="amesos: solver type" type="string" value="Pardiso"/>
        </ParameterList> <!-- Ifpack Settings -->
      </ParameterList> <!-- Ifpack -->
    </ParameterList> <!-- Preconditioner Types -->
  </ParameterList> <!-- Linear Solver -->

  <ParameterList name="Tempus">
    <Parameter name="Integrator Name" type="string" value="Default Integrator"/>
    <ParameterList name="Default Integrator">
      <Parameter name="Integrator Type" type="string" value="Integrator Basic"/>
      <Parameter name="Stepper Name" type="string" value="Default Stepper"/>
      <ParameterList name="Solution History">
        <Parameter name="Storage Type" type="string" value="Undo"/>
        <Parameter name="Storage Limit" type="int" value="2"/>
      </ParameterList> <!-- Solution History -->
      <ParameterList name="Time Step Control">
        <Parameter name="Initial Time" type="double" value="0.0"/>
        <Parameter name="Final Time" type="double" value="1000.0"/>
        <Parameter name="Final Time Index" type="int" value="10000000"/>
        <Parameter name="Minimum Time Step" type="double" value="1.0e-8"/>
        <Parameter name="Initial Time Step" type="double" value="1.0e-3"/>
        <Parameter name="Maximum Time Step" type="double" value="1.0e-1"/>
        <Parameter name="Minimum Order" type="int" value="1"/>
        <Parameter name="Initial Order" type="int" value="1"/>
        <Parameter name="Maximum Order" type="int" value="2"/>
        <Parameter name="Maximum Absolute Error" type="double" value="1.0e-8"/>
        <Parameter name="Maximum Relative Error" type="double" value="1.0e-8"/>
        <Parameter name="Integrator Step Type" type="string" value="Constant"/>
        <Parameter name="Maximum Number of Stepper Failures" type="int" value="10"/>
        <Parameter name="Maximum Number of Consecutive Stepper Failures" type="int" value="5"/>
      </ParameterList> <!-- Time Step Control -->
    </ParameterList> <!-- Default Integrator -->
    <ParameterList name="Default Stepper">
      <Parameter name="Stepper Type" type="string" value="SDIRK 2 Stage 2nd order"/>
      <Parameter name="Solver Name" type="string" value="Default Solver"/>
      <Parameter name="Zero Initial Guess" type="bool" value="false"/>
      <ParameterList name="Default Solver">
        <ParameterList name="NOX">
          <ParameterList name="Direction">
            <Parameter name="Method" type="string" value="Newton"/>
            <ParameterList name="Newton">
              <Parameter name="Forcing Term Method" type="string" value="Constant"/>
              <Parameter name="Rescue Bad Newton Solve" type="bool" value="1"/>
              <ParameterList name="Stratimikos Linear Solver">
                <ParameterList name="NOX Stratimikos Options">
                </ParameterList>
              </ParameterList> <!-- Stratimikos Linear Solver -->
            </ParameterList> <!-- Newton -->
          </ParameterList> <!-- Direction -->
          <ParameterList name="Line Search">
            <Parameter name="Method" type="string" value="Full Step"/>
            <ParameterList name="Full Step">
              <Parameter name="Full Step" type="double" value="1"/>
            </ParameterList> <!-- Full Step -->
          </ParameterList> <!-- Line Search -->
          <Parameter name="Nonlinear Solver" type="string" value="Line Search Based"/>
          <ParameterList name="Printing">
            <Parameter name="Output Precision" type="int" value="3"/>
            <Parameter name="Output Processor" type="int" value="0"/>
            <ParameterList name="Output Information">
              <Parameter name="Error" type="bool" value="1"/>
              <Parameter name="Warning" type="bool" value="1"/>
              <Parameter name="Outer Iteration" type="bool" value="0"/>
              <Parameter name="Parameters" type="bool" value="0"/>
              <Parameter name="Details" type="bool" value="0"/>
              <Parameter name="Linear Solver Details" type="bool" value="0"/>
              <Parameter name="Stepper Iteration" type="bool" value="0"/>
              <Parameter name="Stepper Details" type="bool" value="0"/>
              <Parameter name="Stepper Parameters" type="bool" value="0"/>
            </ParameterList> <!-- Output Information -->
          </ParameterList> <!-- Printing -->
          <ParameterList name="Solver Options">
            <Parameter name="Status Test Check Type" type="string" value="Minimal"/>
          </ParameterList> <!-- Solver Options -->
          <ParameterList name="Status Tests">
            <Parameter name="Test Type" type="string" value="Combo"/>
            <Parameter name="Combo Type" type="string" value="OR"/>
            <Parameter name="Number of Tests" type="int" value="3"/>
            <ParameterList name="Test 0">
              <Parameter name="Test Type" type="string" value="NormF"/>
              <Parameter name="Tolerance" type="double" value="1.0e-8"/>
            </ParameterList> <!-- Test 0 -->
            <ParameterList name="Test 1">
              <Parameter name="Test Type" type="string" value="MaxIters"/>
              <Parameter name="Maximum Iterations" type="int" value="10"/>
            </ParameterList> <!-- Test 1 -->
            <ParameterList name="Test 2">
              <Parameter name="Test Type" type="string" value="NStep"/>
              <Parameter name="Number of Nonlinear Iterations" type="int" value="4"/>
              <Parameter name="Number of Initial Ramping Steps" type="int" value="10"/>
              <Parameter name="Number of Nonlinear Iterations in Ramping Phase" type="int" value="5"/>
            </ParameterList> <!-- Test 2 -->
          </ParameterList> <!-- Status Tests -->
        </ParameterList> <!-- NOX -->
      </ParameterList> <!-- Default Solver -->
    </ParameterList> <!-- Default Stepper -->
  </ParameterList> <!-- Tempus -->

</ParameterList>